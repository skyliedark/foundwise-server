# ────────────────────────────────────────────────
# FoundWise — Environment Variables
# ────────────────────────────────────────────────
# NEVER commit this file to Git!
# Copy this to .env and fill in your real values.

DIDIT_API_KEY=your_didit_api_key_here

# Base URL of the Didit verification API (no trailing slash)
DIDIT_BASE_URL=https://verification.didit.me

# Port this server will listen on
PORT=3000

# Allowed origin for CORS — your frontend's URL
# During local dev: http://localhost:3000
# In production: https://yourdomain.com
ALLOWED_ORIGIN=http://localhost:3000

# ── MySQL / XAMPP database ──────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=foundwise
DB_USER=root
DB_PASS=

# PHP API base URL (XAMPP serves on port 80 by default)
PHP_API_URL=http://localhost/foundwise/api

# ── Gmail SMTP (Nodemailer claim notifications) ───────────────
# The Gmail address that sends claim notification emails
GMAIL_USER=your.school.email@gmail.com
#
# Generate an App Password (NOT your real password!):
#   Google Account → Security → 2-Step Verification → App Passwords
#   Select app: "Mail", device: "Other", name it "FoundWise"
GMAIL_APP_PASSWORD=your_16_char_app_password_here
